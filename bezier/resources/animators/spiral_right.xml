<?xml version="1.0" encoding="ISO-8859-1"?>
<!DOCTYPE animator SYSTEM "../dtd/animator.dtd">
<animator>
    <name>spiral_right</name>
    <keys>
        <key>
            <duration>180.0</duration>
            <tweenMode>TWEENING</tweenMode>
            <easeMode>linear</easeMode>
            <oscillator>none</oscillator>
            <scaleX>0.0</scaleX>
            <scaleY>0.0</scaleY>
            <rotationAngle>0.0</rotationAngle>
            <rotationOffset>0.0</rotationOffset>
            <transX>0.0</transX>
            <transY>0.0</transY>
            <renderer>F_blue_255</renderer>
        </key>
        <key>
            <duration>180.0</duration>
            <tweenMode>TWEENING</tweenMode>
            <easeMode>easeInOutQuad</easeMode>
            <oscillator>none</oscillator>
            <scaleX>5.0</scaleX>
            <scaleY>5.0</scaleY>
            <rotationAngle>2400.0</rotationAngle>
            <rotationOffset>2.0</rotationOffset>
            <transX>40.0</transX>
            <transY>0.0</transY>
            <renderer>F_blue_255</renderer>
        </key>
    </keys>
</animator>
