<?xml version="1.0" encoding="ISO-8859-1"?>
<!DOCTYPE animator SYSTEM "../dtd/animator.dtd">
<animator>
    <name>reverse</name>
    <keys>
        <key>
            <duration>180.0</duration>
            <tweenMode>DISCRETE</tweenMode>
            <easeMode>linear</easeMode>
            <oscillator>osc_01</oscillator>
            <scaleX>-1.0</scaleX>
            <scaleY>1</scaleY>
            <rotationAngle>0.0</rotationAngle>
            <rotationOffset>0.0</rotationOffset>
            <transX>0.0</transX>
            <transY>0.0</transY>
            <renderer>F_blue_255</renderer>
        </key>
    </keys>
</animator>
